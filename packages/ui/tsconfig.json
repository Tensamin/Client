{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/link.tsx",
    "src/libs/cn.ts",
    "src/screens/error.tsx",
    "src/screens/loading.tsx",
    "src/ui/avatar.tsx",
    "src/ui/button.tsx",
    "src/ui/card.tsx",
    "src/ui/checkbox.tsx",
    "src/ui/context-menu.tsx",
    "src/ui/input.tsx",
    "src/ui/label.tsx",
    "src/ui/sonner.tsx"
  ]
}
